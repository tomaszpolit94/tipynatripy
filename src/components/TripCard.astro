---
interface Props {
  title: string;
  destination: string;
  duration: string;
  budget?: string;
  heroImage?: string;
  slug: string;
  tags?: string[];
  difficulty?: string;
  description?: string;
}

const {
  title,
  destination,
  duration,
  budget,
  heroImage,
  slug,
  tags = [],
  difficulty = 'łatwy',
  description,
} = Astro.props;

const difficultyColor: Record<string, string> = {
  łatwy: 'bg-green-500',
  średni: 'bg-amber-500',
  wymagający: 'bg-red-500',
};
---

<a
  href={`/plany/${slug}/`}
  class="group flex flex-col bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
>
  <!-- Image container -->
  <div class="relative h-56 overflow-hidden bg-sky-100 flex-shrink-0">
    {
      heroImage ? (
        <img
          src={heroImage}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-sky-400 to-sky-700 flex items-center justify-center text-7xl">
          ✈️
        </div>
      )
    }

    <!-- Duration badge top-left -->
    <div
      class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-sky-700 font-bold text-xs px-3 py-1.5 rounded-full shadow-sm"
    >
      ⏱ {duration}
    </div>

    <!-- Difficulty dot top-right -->
    <div
      class={`absolute top-3 right-3 w-3 h-3 rounded-full shadow ${difficultyColor[difficulty] ?? 'bg-gray-400'}`}
      title={`Poziom: ${difficulty}`}
    >
    </div>

    <!-- Budget badge bottom-right -->
    {
      budget && (
        <div class="absolute bottom-0 right-0 bg-amber-500 text-white font-extrabold text-base px-4 py-2 rounded-tl-xl shadow-lg">
          {budget}
        </div>
      )
    }

    <!-- Gradient overlay bottom -->
    <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-black/40 to-transparent">
    </div>

    <!-- Destination label on image -->
    <div class="absolute bottom-3 left-3 text-white text-sm font-semibold drop-shadow">
      📍 {destination}
    </div>
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col flex-1">
    <h3
      class="text-lg font-bold text-gray-900 group-hover:text-sky-600 transition-colors leading-snug mb-2"
    >
      {title}
    </h3>

    {
      description && (
        <p class="text-sm text-gray-500 line-clamp-2 mb-3 flex-1">{description}</p>
      )
    }

    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1 mb-4">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-xs bg-sky-50 text-sky-600 px-2 py-0.5 rounded-full">{tag}</span>
          ))}
        </div>
      )
    }

    <div class="pt-3 border-t border-gray-100 flex items-center justify-between mt-auto">
      <span class="text-xs text-gray-400 capitalize">Poziom: {difficulty}</span>
      <span
        class="inline-flex items-center gap-1 bg-sky-600 group-hover:bg-sky-700 text-white text-sm font-semibold px-4 py-1.5 rounded-full transition-colors"
      >
        Zobacz plan →
      </span>
    </div>
  </div>
</a>
