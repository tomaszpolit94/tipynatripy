---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-100 mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand + Social -->
      <div class="md:col-span-1">
        <h3 class="text-sky-600 font-bold text-lg mb-2">Tipynatripy</h3>
        <p class="text-gray-500 text-sm mb-4">
          Tanie loty, praktyczne tipy podróżne i inspirujące plany wycieczek dla polskich
          podróżników.
        </p>
        <!-- Social media icons -->
        <div class="flex gap-3 flex-wrap">
          <!-- Facebook -->
          <a href="#" aria-label="Facebook" class="text-gray-400 hover:text-sky-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="text-gray-400 hover:text-pink-500 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <!-- TikTok -->
          <a href="#" aria-label="TikTok" class="text-gray-400 hover:text-gray-900 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
            </svg>
          </a>
          <!-- YouTube -->
          <a href="#" aria-label="YouTube" class="text-gray-400 hover:text-red-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/>
            </svg>
          </a>
          <!-- Pinterest -->
          <a href="#" aria-label="Pinterest" class="text-gray-400 hover:text-red-500 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
            </svg>
          </a>
          <!-- X (Twitter) -->
          <a href="#" aria-label="X (Twitter)" class="text-gray-400 hover:text-gray-900 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Sekcje -->
      <div>
        <h4 class="font-semibold text-gray-700 mb-3 text-sm uppercase tracking-wide">Sekcje</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/blog/" class="text-gray-500 hover:text-sky-600 transition-colors">Blog</a></li>
          <li><a href="/loty/" class="text-gray-500 hover:text-sky-600 transition-colors">Loty</a></li>
          <li><a href="/okazje/" class="text-gray-500 hover:text-sky-600 transition-colors">Okazje</a></li>
          <li><a href="/tipy/" class="text-gray-500 hover:text-sky-600 transition-colors">Tipy</a></li>
          <li><a href="/plany/" class="text-gray-500 hover:text-sky-600 transition-colors">Plany</a></li>
        </ul>
      </div>

      <!-- Popularne kierunki -->
      <div>
        <h4 class="font-semibold text-gray-700 mb-3 text-sm uppercase tracking-wide">Popularne kierunki</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/blog/top-10-atrakcji-rzym/" class="text-gray-500 hover:text-sky-600 transition-colors">Rzym</a></li>
          <li><a href="/blog/top-10-atrakcji-paryz/" class="text-gray-500 hover:text-sky-600 transition-colors">Paryż</a></li>
          <li><a href="/blog/top-10-atrakcji-barcelona/" class="text-gray-500 hover:text-sky-600 transition-colors">Barcelona</a></li>
          <li><a href="/blog/top-10-atrakcji-londyn/" class="text-gray-500 hover:text-sky-600 transition-colors">Londyn</a></li>
          <li><a href="/blog/top-10-atrakcji-dubaj/" class="text-gray-500 hover:text-sky-600 transition-colors">Dubaj</a></li>
          <li><a href="/blog/top-10-atrakcji-nowy-jork/" class="text-gray-500 hover:text-sky-600 transition-colors">Nowy Jork</a></li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h4 class="font-semibold text-gray-700 mb-3 text-sm uppercase tracking-wide">
          Informacje
        </h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/o-nas/" class="text-gray-500 hover:text-sky-600 transition-colors">O nas</a>
          </li>
          <li>
            <a href="/kontakt/" class="text-gray-500 hover:text-sky-600 transition-colors">Kontakt</a>
          </li>
          <li>
            <a href="/polityka-prywatnosci/" class="text-gray-500 hover:text-sky-600 transition-colors">Polityka prywatności</a>
          </li>
          <li>
            <a href="/regulamin/" class="text-gray-500 hover:text-sky-600 transition-colors">Regulamin</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-100 mt-8 pt-6 text-center text-sm text-gray-400">
      <p>© {currentYear} Tipynatripy. Wszelkie prawa zastrzeżone.</p>
      <p class="mt-1">Niektóre linki na stronie mogą być linkami afiliacyjnymi.</p>
    </div>
  </div>
</footer>
