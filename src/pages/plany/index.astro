---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TripCard from '../../components/TripCard.astro';
import { getCollection } from 'astro:content';

const plany = (await getCollection('plany', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Plany wycieczek — gotowe itineraria"
  description="Gotowe plany wycieczek na 3, 5 i 7 dni. Sprawdzone trasy, atrakcje i wskazówki dla polskich podróżników."
>
  <div class="bg-gradient-to-r from-sky-600 to-sky-700 text-white py-14 px-4">
    <div class="max-w-6xl mx-auto">
      <nav class="text-sm text-sky-200 mb-4">
        <a href="/" class="hover:text-white transition-colors">Strona główna</a>
        <span class="mx-2">/</span>
        <span class="text-white">Plany</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3">Plany wycieczek 🗺️</h1>
      <p class="text-sky-100 text-lg max-w-2xl">
        Gotowe itineraria z szacunkowym budżetem. Skopiuj, spakuj walizkę i jedź!
      </p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {
      plany.length === 0 ? (
        <div class="text-center py-24">
          <div class="text-6xl mb-4">🗺️</div>
          <p class="text-gray-400 text-lg">Plany wycieczek wkrótce!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {plany.map((plan) => (
            <TripCard
              title={plan.data.title}
              destination={plan.data.destination}
              duration={plan.data.duration}
              budget={plan.data.budget}
              heroImage={plan.data.heroImage}
              slug={plan.slug}
              tags={plan.data.tags}
              difficulty={plan.data.difficulty}
              description={plan.data.description}
            />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
