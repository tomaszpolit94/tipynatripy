---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSenseSlot from '../../components/AdSenseSlot.astro';

export async function getStaticPaths() {
  const articles = await getCollection('loty', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const formattedDate = article.data.pubDate.toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  ogImage={article.data.heroImage}
  type="article"
  pubDate={article.data.pubDate}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/" class="hover:text-sky-600">Strona główna</a>
      <span class="mx-2">/</span>
      <a href="/loty/" class="hover:text-sky-600">Loty</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">{article.data.title}</span>
    </nav>

    <header class="mb-8">
      {
        article.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {article.data.tags.map((tag) => (
              <span class="text-xs bg-sky-50 text-sky-600 px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )
      }
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 leading-tight mb-4">
        {article.data.title}
      </h1>
      <time datetime={article.data.pubDate.toISOString()} class="text-sm text-gray-400">
        {formattedDate}
      </time>
      {
        article.data.heroImage && (
          <img
            src={article.data.heroImage}
            alt={article.data.title}
            class="w-full rounded-xl mt-6 shadow-md"
            loading="eager"
          />
        )
      }
    </header>

    <AdSenseSlot slotId="2234567891" />

    <div class="prose prose-lg prose-sky max-w-none">
      <Content />
    </div>

    <AdSenseSlot slotId="2234567892" />

    <div class="mt-10 pt-6 border-t border-gray-100">
      <a href="/loty/" class="text-sky-600 hover:text-sky-700 font-medium transition-colors">
        ← Wszystkie artykuły o lotach
      </a>
    </div>
  </article>
</BaseLayout>
