---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import TripCard from '../components/TripCard.astro';
import AnimatedPlane from '../components/AnimatedPlane.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const featuredPlans = (await getCollection('plany', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const sections = [
  {
    href: '/loty/',
    title: 'Loty',
    desc: 'Jak znaleźć najtańsze bilety lotnicze i kiedy kupować.',
    icon: '✈️',
  },
  {
    href: '/okazje/',
    title: 'Okazje',
    desc: 'Aktualne promocje lotnicze i wyjątkowe oferty.',
    icon: '🏷️',
  },
  {
    href: '/tipy/',
    title: 'Tipy',
    desc: 'Pakowanie, ubezpieczenia, wizy — wszystko co musisz wiedzieć.',
    icon: '💡',
  },
  {
    href: '/plany/',
    title: 'Plany',
    desc: 'Gotowe itineraria na 3, 5 lub 7 dni w dowolnym miejscu.',
    icon: '🗺️',
  },
];
---

<BaseLayout
  title="Strona główna"
  description="Tipynatripy — tanie loty, praktyczne tipy podróżne i gotowe plany wycieczek dla polskich podróżników."
>
  <!-- Hero z animowanym samolotem -->
  <section class="relative bg-gradient-to-br from-sky-500 via-sky-600 to-sky-800 text-white py-24 px-4 overflow-hidden">
    <AnimatedPlane />

    <!-- Dekoracyjne chmurki -->
    <div class="absolute top-8 right-16 w-36 h-14 bg-white/10 rounded-full blur-2xl pointer-events-none"></div>
    <div class="absolute bottom-10 left-24 w-52 h-16 bg-white/8 rounded-full blur-2xl pointer-events-none"></div>
    <div class="absolute top-1/2 right-1/3 w-24 h-10 bg-white/5 rounded-full blur-xl pointer-events-none"></div>

    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-sky-200 text-sm font-semibold uppercase tracking-widest mb-3">
        Twój przewodnik podróżniczy
      </p>
      <h1 class="text-4xl md:text-6xl font-extrabold mb-5 leading-tight drop-shadow-sm">
        Podróżuj mądrzej,<br />
        <span class="text-amber-300">wydawaj mniej</span>
      </h1>
      <p class="text-xl text-sky-100 mb-10 max-w-2xl mx-auto leading-relaxed">
        Tanie loty, praktyczne tipy i gotowe plany wycieczek — wszystko po polsku.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/loty/"
          class="bg-white text-sky-700 font-bold px-8 py-3.5 rounded-full hover:bg-sky-50 transition-colors shadow-lg text-base"
        >
          Jak latać tanio
        </a>
        <a
          href="/plany/"
          class="border-2 border-white/80 text-white font-bold px-8 py-3.5 rounded-full hover:bg-white/10 transition-colors text-base"
        >
          Plany wycieczek
        </a>
      </div>
    </div>
  </section>

  <!-- Sections grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">
      Co znajdziesz na Tipynatripy?
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {
        sections.map(({ href, title, desc, icon }) => (
          <a
            href={href}
            class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-sky-200 transition-all group"
          >
            <div class="text-3xl mb-3">{icon}</div>
            <h3 class="font-bold text-gray-900 group-hover:text-sky-600 transition-colors mb-2">
              {title}
            </h3>
            <p class="text-sm text-gray-500">{desc}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Featured trip plans -->
  {
    featuredPlans.length > 0 && (
      <section class="bg-gray-50 py-16">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between mb-10">
            <div>
              <h2 class="text-3xl font-extrabold text-gray-900">Polecane plany wycieczek</h2>
              <p class="text-gray-500 mt-1">Gotowe itineraria z szacunkowym budżetem</p>
            </div>
            <a
              href="/plany/"
              class="hidden sm:inline-flex items-center gap-2 bg-sky-600 text-white font-semibold px-5 py-2.5 rounded-full hover:bg-sky-700 transition-colors text-sm"
            >
              Wszystkie plany →
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {featuredPlans.map((plan) => (
              <TripCard
                title={plan.data.title}
                destination={plan.data.destination}
                duration={plan.data.duration}
                budget={plan.data.budget}
                heroImage={plan.data.heroImage}
                slug={plan.slug}
                tags={plan.data.tags}
                difficulty={plan.data.difficulty}
                description={plan.data.description}
              />
            ))}
          </div>
          <div class="text-center mt-8 sm:hidden">
            <a
              href="/plany/"
              class="inline-flex items-center gap-2 bg-sky-600 text-white font-semibold px-6 py-3 rounded-full hover:bg-sky-700 transition-colors"
            >
              Wszystkie plany →
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- Latest blog posts -->
  {
    latestPosts.length > 0 && (
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Ostatnie artykuły</h2>
            <p class="text-gray-500 text-sm mt-1">Inspiracje i porady podróżnicze</p>
          </div>
          <a href="/blog/" class="text-sky-600 hover:text-sky-700 text-sm font-medium transition-colors">
            Wszystkie artykuły →
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.slug}
              section="blog"
              tags={post.data.tags}
              heroImage={post.data.heroImage}
            />
          ))}
        </div>
      </section>
    )
  }

  <!-- CTA banner -->
  <section class="bg-sky-600 text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold mb-4">Gotowy na następną przygodę?</h2>
      <p class="text-sky-100 mb-8 text-lg">
        Sprawdź nasze tipy i zaoszczędź na kolejnym wylocie.
      </p>
      <a
        href="/tipy/"
        class="bg-white text-sky-700 font-bold px-8 py-3.5 rounded-full hover:bg-sky-50 transition-colors shadow-lg"
      >
        Przeglądaj tipy
      </a>
    </div>
  </section>
</BaseLayout>
