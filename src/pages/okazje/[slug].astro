---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSenseSlot from '../../components/AdSenseSlot.astro';

export async function getStaticPaths() {
  const items = await getCollection('okazje', ({ data }) => !data.draft);
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const formattedDate = item.data.pubDate.toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const validUntil = item.data.validUntil?.toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={item.data.title}
  description={item.data.description}
  ogImage={item.data.heroImage}
  type="article"
  pubDate={item.data.pubDate}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/" class="hover:text-sky-600">Strona główna</a>
      <span class="mx-2">/</span>
      <a href="/okazje/" class="hover:text-sky-600">Okazje</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">{item.data.title}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 leading-tight mb-4">
        {item.data.title}
      </h1>

      <!-- Okazja details -->
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 flex flex-wrap gap-4">
        <div class="flex items-center gap-2">
          <span class="text-gray-500 text-sm">Destynacja:</span>
          <span class="font-semibold text-gray-800">📍 {item.data.destination}</span>
        </div>
        {
          item.data.price && (
            <div class="flex items-center gap-2">
              <span class="text-gray-500 text-sm">Cena od:</span>
              <span class="font-extrabold text-amber-600 text-lg">{item.data.price}</span>
            </div>
          )
        }
        {
          item.data.airline && (
            <div class="flex items-center gap-2">
              <span class="text-gray-500 text-sm">Linia:</span>
              <span class="font-semibold text-gray-800">{item.data.airline}</span>
            </div>
          )
        }
        {
          validUntil && (
            <div class="flex items-center gap-2">
              <span class="text-gray-500 text-sm">Ważna do:</span>
              <span class="font-semibold text-red-600">{validUntil}</span>
            </div>
          )
        }
      </div>

      <time datetime={item.data.pubDate.toISOString()} class="text-sm text-gray-400">
        Dodano: {formattedDate}
      </time>
    </header>

    <AdSenseSlot slotId="3234567891" />

    <div class="prose prose-lg prose-sky max-w-none">
      <Content />
    </div>

    <AdSenseSlot slotId="3234567892" />

    <div class="mt-10 pt-6 border-t border-gray-100">
      <a href="/okazje/" class="text-sky-600 hover:text-sky-700 font-medium transition-colors">
        ← Wszystkie okazje
      </a>
    </div>
  </article>
</BaseLayout>
