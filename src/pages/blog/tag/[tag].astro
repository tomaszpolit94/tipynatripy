---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  posts.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));

  return Array.from(tagSet).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`#${tag} — artykuły podróżne`}
  description={`Wszystkie artykuły z tagiem ${tag}. Porady, przewodniki i inspiracje podróżnicze.`}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-400 mb-8">
      <a href="/" class="hover:text-sky-600">Strona główna</a>
      <span class="mx-2">/</span>
      <a href="/blog/" class="hover:text-sky-600">Blog</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">#{tag}</span>
    </nav>

    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-2">
        <span class="text-sky-600">#</span>{tag}
      </h1>
      <p class="text-gray-500">{posts.length} {posts.length === 1 ? 'artykuł' : posts.length < 5 ? 'artykuły' : 'artykułów'}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.slug}
          section="blog"
          tags={post.data.tags}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>
  </div>
</BaseLayout>
