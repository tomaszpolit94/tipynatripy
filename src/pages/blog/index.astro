---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog podróżniczy"
  description="Artykuły o tanich lotach, podróżach i wskazówki dla podróżników. Regularnie aktualizowane porady i inspiracje."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-8">
      <a href="/" class="hover:text-sky-600">Strona główna</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">Blog</span>
    </nav>

    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-3">Blog podróżniczy</h1>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        Artykuły, porady i inspiracje dla oszczędnych podróżników.
      </p>
    </div>

    <AdSlot position="blog-list-top" />

    {
      posts.length === 0 ? (
        <p class="text-center text-gray-400 py-16 text-lg">Artykuły wkrótce!</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.slug}
              section="blog"
              tags={post.data.tags}
              heroImage={post.data.heroImage}
            />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
