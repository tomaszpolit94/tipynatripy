---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  section: string;
  tags?: string[];
  heroImage?: string;
}

const { title, description, pubDate, slug, section, tags = [], heroImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const url = `/${section}/${slug}/`;
---

<article
  class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow flex flex-col"
>
  {
    heroImage && (
      <a href={url} tabindex="-1" aria-hidden="true">
        <img src={heroImage} alt={title} class="w-full h-48 object-cover" loading="lazy" />
      </a>
    )
  }
  <div class="p-5 flex flex-col flex-1">
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1 mb-3">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-xs bg-sky-50 text-sky-600 px-2 py-0.5 rounded-full">{tag}</span>
          ))}
        </div>
      )
    }
    <h2 class="text-lg font-bold text-gray-900 mb-2 leading-snug">
      <a href={url} class="hover:text-sky-600 transition-colors">{title}</a>
    </h2>
    <p class="text-gray-500 text-sm mb-4 line-clamp-3 flex-1">{description}</p>
    <div class="flex items-center justify-end mt-auto pt-3 border-t border-gray-50">
      <a href={url} class="text-sm font-medium text-sky-600 hover:text-sky-700 transition-colors">
        Czytaj więcej →
      </a>
    </div>
  </div>
</article>
