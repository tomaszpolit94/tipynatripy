---
import { getCollection, render } from 'astro:content';
import AdSlot from '../../components/AdSlot.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSenseSlot from '../../components/AdSenseSlot.astro';

export async function getStaticPaths() {
  const plany = await getCollection('plany', ({ data }) => !data.draft);
  return plany.map((plan) => ({
    params: { slug: plan.slug },
    props: { plan },
  }));
}

const { plan } = Astro.props;
const { Content } = await render(plan);

// Cross-collection links: blog top-10 for same destination + visa tipy
const allBlog = await getCollection('blog', ({ data }) => !data.draft);
const destLower = plan.data.destination.toLowerCase();
const relatedBlog = allBlog
  .filter((p) => p.slug.includes('top-10') && p.data.tags.some((t) => t.toLowerCase().includes(destLower)))
  .slice(0, 2);

const allTipy = await getCollection('tipy', ({ data }) => !data.draft);
const relatedTipy = allTipy
  .filter((t) => t.data.tags.some((tag) => tag.toLowerCase().includes(destLower)))
  .slice(0, 2);

const difficultyColors: Record<string, string> = {
  łatwy: 'bg-green-50 text-green-700 border-green-200',
  średni: 'bg-amber-50 text-amber-700 border-amber-200',
  wymagający: 'bg-red-50 text-red-700 border-red-200',
};
---

<BaseLayout
  title={plan.data.title}
  description={plan.data.description}
  ogImage={plan.data.heroImage}
  type="article"
  pubDate={plan.data.pubDate}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/" class="hover:text-sky-600">Strona główna</a>
      <span class="mx-2">/</span>
      <a href="/plany/" class="hover:text-sky-600">Plany</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">{plan.data.title}</span>
    </nav>

    <header class="mb-8">
      {
        plan.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {plan.data.tags.map((tag) => (
              <span class="text-xs bg-sky-50 text-sky-600 px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )
      }
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 leading-tight mb-4">
        {plan.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-400 mb-4">
        <span class="font-medium text-gray-600">Redakcja Tipynatripy</span>
        <span aria-hidden="true">·</span>
        <time datetime={plan.data.pubDate.toISOString()}>{plan.data.pubDate.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </div>

      <!-- Plan summary -->
      <div
        class={`border rounded-xl p-4 mb-6 flex flex-wrap gap-4 ${difficultyColors[plan.data.difficulty]}`}
      >
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium">📍 {plan.data.destination}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium">⏱ {plan.data.duration}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium capitalize">Poziom: {plan.data.difficulty}</span>
        </div>
      </div>

      {
        plan.data.heroImage && (
          <img
            src={plan.data.heroImage}
            alt={plan.data.title}
            class="w-full rounded-xl mt-6 shadow-md"
            loading="eager"
          />
        )
      }
    </header>

    <AdSenseSlot slotId="5234567891" />

    <div class="prose prose-lg prose-sky max-w-none">
      <Content />
    </div>

    <AdSenseSlot slotId="5234567892" />

    <!-- Cross-collection related links -->
    {(relatedBlog.length > 0 || relatedTipy.length > 0) && (
      <aside class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-xl font-bold text-gray-900 mb-5">Przydatne informacje</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {relatedBlog.map((p) => (
            <a href={`/blog/${p.slug}/`} class="group flex gap-3 bg-white rounded-xl border border-gray-100 p-4 hover:shadow-md transition-shadow">
              {p.data.heroImage && (
                <img src={p.data.heroImage} alt={p.data.title} class="w-16 h-16 rounded-lg object-cover flex-shrink-0" loading="lazy" width="64" height="64" />
              )}
              <div>
                <span class="text-xs text-sky-600 font-medium uppercase tracking-wide">Top 10</span>
                <h3 class="text-sm font-semibold text-gray-900 group-hover:text-sky-600 transition-colors leading-snug mt-1 line-clamp-2">{p.data.title}</h3>
              </div>
            </a>
          ))}
          {relatedTipy.map((t) => (
            <a href={`/tipy/${t.slug}/`} class="group flex gap-3 bg-white rounded-xl border border-gray-100 p-4 hover:shadow-md transition-shadow">
              {t.data.heroImage && (
                <img src={t.data.heroImage} alt={t.data.title} class="w-16 h-16 rounded-lg object-cover flex-shrink-0" loading="lazy" width="64" height="64" />
              )}
              <div>
                <span class="text-xs text-amber-600 font-medium uppercase tracking-wide">Tip</span>
                <h3 class="text-sm font-semibold text-gray-900 group-hover:text-sky-600 transition-colors leading-snug mt-1 line-clamp-2">{t.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </aside>
    )}

    <div class="mt-10 pt-6 border-t border-gray-100">
      <a href="/plany/" class="text-sky-600 hover:text-sky-700 font-medium transition-colors">
        ← Wszystkie plany wycieczek
      </a>
    </div>
  </article>
</BaseLayout>
