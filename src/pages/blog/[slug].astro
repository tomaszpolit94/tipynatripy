---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get related posts (same tags, exclude current)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(
    (p) =>
      p.slug !== post.slug &&
      p.data.tags.some((tag) => post.data.tags.includes(tag))
  )
  .slice(0, 3);

// Related plany — match by tags overlap
const allPlany = await getCollection('plany', ({ data }) => !data.draft);
const relatedPlany = allPlany
  .filter((p) => p.data.tags.some((tag) => post.data.tags.includes(tag)))
  .slice(0, 2);

const formattedDate = post.data.pubDate.toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const updatedDate = post.data.updatedDate?.toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Estimate reading time (~200 words per minute)
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.heroImage}
  type="article"
  pubDate={post.data.pubDate}
  articleUpdatedDate={post.data.updatedDate}
  keywords={post.data.tags}
  author={post.data.author}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1">
        <li><a href="/" class="hover:text-sky-600 transition-colors">Strona główna</a></li>
        <li aria-hidden="true"><span class="mx-1">/</span></li>
        <li><a href="/blog/" class="hover:text-sky-600 transition-colors">Blog</a></li>
        <li aria-hidden="true"><span class="mx-1">/</span></li>
        <li class="text-gray-600 line-clamp-1">{post.data.title}</li>
      </ol>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      {
        post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {post.data.tags.map((tag) => (
              <a href={`/blog/tag/${tag}/`} class="text-xs bg-sky-50 text-sky-600 px-3 py-1 rounded-full hover:bg-sky-100 transition-colors">{tag}</a>
            ))}
          </div>
        )
      }
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 leading-tight mb-4">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-400">
        <span class="font-medium text-gray-600">{post.data.author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={post.data.pubDate.toISOString()} class="text-gray-400">
          {formattedDate}
        </time>
        {updatedDate && (
          <span class="text-xs bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full border border-amber-200">
            Zaktualizowano: {updatedDate}
          </span>
        )}
      </div>
      {
        post.data.heroImage && (
          <img
            src={post.data.heroImage}
            alt={post.data.title}
            class="w-full rounded-xl mt-6 shadow-md aspect-video object-cover"
            loading="eager"
            width="800"
            height="450"
          />
        )
      }
    </header>

    <!-- Content -->
    <div class="prose prose-lg prose-sky max-w-none prose-headings:scroll-mt-20 prose-img:rounded-xl prose-img:shadow-md prose-img:mx-auto prose-a:text-sky-600 prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>

    <!-- Author bio -->
    <div class="mt-12 pt-8 border-t border-gray-100">
      <div class="flex items-start gap-4 bg-gray-50 rounded-2xl p-6">
        <div class="flex-shrink-0 w-14 h-14 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 text-2xl font-bold select-none">
          T
        </div>
        <div>
          <p class="font-semibold text-gray-900 text-sm mb-1">{post.data.author}</p>
          <p class="text-gray-500 text-sm leading-relaxed">
            Tipynatripy to serwis podróżniczy dla Polaków, którzy chcą zwiedzać świat bez przepłacania.
            Piszemy o tanich lotach, praktycznych tipach, planach wycieczek i okazjach lotniczych.
            Każdy artykuł oparty jest na sprawdzonych informacjach i aktualnych cenach.
          </p>
          <a href="/o-nas/" class="text-sky-600 hover:text-sky-700 text-sm font-medium mt-2 inline-block transition-colors">
            Więcej o redakcji →
          </a>
        </div>
      </div>
    </div>

    <!-- Related posts -->
    {
      relatedPosts.length > 0 && (
        <aside class="mt-12 pt-8 border-t border-gray-100">
          <h2 class="text-xl font-bold text-gray-900 mb-5">Podobne artykuły</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {relatedPosts.map((p) => (
              <a
                href={`/blog/${p.slug}/`}
                class="group block bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-md transition-shadow"
              >
                {p.data.heroImage && (
                  <img
                    src={p.data.heroImage}
                    alt={p.data.title}
                    class="w-full h-32 object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    width="400"
                    height="128"
                  />
                )}
                <div class="p-3">
                  <h3 class="text-sm font-semibold text-gray-900 group-hover:text-sky-600 transition-colors line-clamp-2 leading-snug">
                    {p.data.title}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </aside>
      )
    }

    <!-- Newsletter -->
    <div class="mt-10">
      <NewsletterSignup variant="compact" />
    </div>

    <!-- Related travel plans -->
    {relatedPlany.length > 0 && (
      <aside class="mt-10 pt-8 border-t border-gray-100">
        <h2 class="text-xl font-bold text-gray-900 mb-5">Plany wycieczek</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {relatedPlany.map((p) => (
            <a href={`/plany/${p.slug}/`} class="group flex gap-3 bg-sky-50 rounded-xl border border-sky-100 p-4 hover:shadow-md transition-shadow">
              {p.data.heroImage && (
                <img src={p.data.heroImage} alt={p.data.title} class="w-16 h-16 rounded-lg object-cover flex-shrink-0" loading="lazy" width="64" height="64" />
              )}
              <div>
                <span class="text-xs text-sky-600 font-medium uppercase tracking-wide">Plan wycieczki · {p.data.duration}</span>
                <h3 class="text-sm font-semibold text-gray-900 group-hover:text-sky-600 transition-colors leading-snug mt-1 line-clamp-2">{p.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </aside>
    )}

    <!-- Back link -->
    <div class="mt-10 pt-6 border-t border-gray-100">
      <a href="/blog/" class="text-sky-600 hover:text-sky-700 font-medium transition-colors">
        ← Wszystkie artykuły
      </a>
    </div>
  </article>
</BaseLayout>
